# ─────────────────────────────────────────────
# AI SQL Agent — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# Groq API Key (get one free at https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Database URL (default: SQLite file in data/ directory)
DATABASE_URL=sqlite:///data/company.db

# Server Configuration
HOST=0.0.0.0
PORT=8000
